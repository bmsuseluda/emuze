{
  "name": "emuze",
  "description": "Launch your Retro Games fast and simple",
  "version": "0.58.0",
  "author": "bmsuseluda <gunslinger@sensonar.de>",
  "email": "gunslinger@sensonar.de",
  "url": "https://github.com/bmsuseluda/emuze",
  "license": "GNU GPLv3",
  "scripts": {
    "prepare": "husky install && yarn panda:codegen",
    "clean": "del-cli dist build buildDesktop public/build coverage",
    "panda:codegen": "panda codegen --clean",
    "dev": "yarn clean && yarn panda:codegen && yarn transpileConfigs && react-router dev",
    "dev:electron": "yarn clean && yarn panda:codegen && yarn build:electron && yarn transpileConfigs && cross-env NODE_ENV=development electron --ozone-platform=x11 ./buildDesktop/desktop/main.js",
    "transpileConfigs": "tsc -p ./configsToTs/tsconfig.json && shx cp -r ./buildConfig/* .",
    "build": "yarn clean && cross-env NODE_ENV=production yarn panda:codegen && concurrently -c 'auto' --kill-others-on-fail 'yarn:build:*'",
    "build:remix": "yarn transpileConfigs && react-router build",
    "build:electron": "tsc -p ./desktop/tsconfig.json && shx mv ./buildDesktop/desktop/preload.js ./buildDesktop/desktop/preload.mjs",
    "serve:remix": "react-router-serve ./build/server/index.js",
    "test": "vitest run --passWithNoTests",
    "lint": "concurrently -c 'auto' --kill-others-on-fail 'yarn:lint:*'",
    "lint:lint": "oxlint --fix",
    "lint:circularDependencies": "madge --circular --extensions ts,tsx --exclude 'styled-system' ./app",
    "lint:tsc": "react-router typegen && tsc --noEmit",
    "generate:icon": "tsx ./generateIcon/index.ts",
    "generate:readme": "del-cli ./readme/build && tsc -p ./readme/tsconfig.json && mmarkdown && git add README.md",
    "import": "concurrently -c 'auto' --kill-others-on-fail 'yarn:import:*'",
    "import:mame": "tsx generateNameMappings/mame/index.ts",
    "import:scummvm": "tsx generateNameMappings/scummvm/index.ts",
    "import:cemu": "tsx generateNameMappings/cemu/index.ts",
    "import:rpcs3": "tsx generateNameMappings/rpcs3/index.ts",
    "import:sdlMappings": "tsx fetchSdlMappings/index.ts",
    "convertSvgs": "svgr --svgo-config svgo.config.js --config-file .svgrrc.js ./svgs",
    "download": "concurrently -c 'auto' --kill-others-on-fail 'yarn:download:*'",
    "download:emulators": "tsx ./downloadEmulators/index.ts && yarn import:sdlMappings",
    "download:biosOpenSource": "tsx ./downloadBiosOpenSource/index.ts",
    "dumpGame:cd": "tsx dumpGames/dumpCdAndConvert.ts",
    "dumpGame:dvd": "tsx dumpGames/dumpDvdAndConvert.ts",
    "convertAllToChd": "tsx dumpGames/convertAllToChd.ts",
    "fetchMetaData:prepareNameMappings": "tsx fetchMetaData/prepareNameMappings.ts",
    "fetchMetaData": "yarn fetchMetaData:prepareNameMappings && tsx fetchMetaData/fetchMetaDataForAllSystems.ts",
    "app:dir": "yarn build && electron-builder --dir --config electron-builder.config.js",
    "app:distBase": "yarn download && yarn build && electron-builder --config electron-builder.config.js",
    "app:distLinux": "yarn app:distBase --linux",
    "app:distWindows": "yarn app:distBase --windows",
    "storybook": "yarn clean && cross-env NODE_ENV=development yarn panda:codegen && storybook dev -p 6006 --no-open",
    "e2e": "yarn clean && cross-env NODE_ENV=production yarn panda:codegen && yarn build:remix && concurrently -c 'auto' --kill-others -P 'yarn:e2e:serveRemix:*' 'yarn:e2e:playwright {@}'",
    "e2e:serveRemix:default": "tsx e2eTests/tests/default/start.ts",
    "e2e:serveRemix:initial": "tsx e2eTests/tests/initial/start.ts",
    "e2e:serveRemix:initialWindows": "tsx e2eTests/tests/initialWindows/start.ts",
    "e2e:serveRemix:defaultWindows": "tsx e2eTests/tests/defaultWindows/start.ts",
    "e2e:serveRemix:defaultWithLastPlayed": "tsx e2eTests/tests/defaultWithLastPlayed/start.ts",
    "e2e:serveRemix:wrongRomsPath": "tsx e2eTests/tests/wrongRomsPath/start.ts",
    "e2e:serveRemix:wrongRomsPathWindows": "tsx e2eTests/tests/wrongRomsPathWindows/start.ts",
    "e2e:playwright": "playwright test --ui",
    "e2e:updateSnapshots": "yarn e2e -- --update-snapshots"
  },
  "dependencies": {
    "@kmamal/sdl": "0.11.13",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-select": "2.3.0",
    "@react-router/node": "7.17.0",
    "@react-router/serve": "7.17.0",
    "@ultirequiem/roman": "1.1.0",
    "dotenv": "17.4.2",
    "electron-updater": "6.8.9",
    "fast-xml-builder": "1.2.0",
    "fast-xml-parser": "5.8.0",
    "is-ci": "4.1.0",
    "isbot": "5.1.42",
    "lodash.debounce": "4.0.8",
    "mime": "4.1.0",
    "node-hid": "3.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.5.0",
    "react-markdown": "10.1.0",
    "react-router": "7.17.0",
    "react-use": "17.6.1",
    "remark-gfm": "4.0.1",
    "tree-kill": "1.2.2",
    "vite": "8.0.16",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "7zip-min": "3.0.1",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@felipecrs/decompress-tarxz": "5.0.6",
    "@pandacss/dev": "1.11.3",
    "@playwright/test": "1.60.0",
    "@react-router/dev": "7.17.0",
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-links": "10.4.4",
    "@storybook/react-vite": "10.4.4",
    "@svgr/cli": "8.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/7zip-min": "2.0.0",
    "@types/decompress": "4.2.7",
    "@types/follow-redirects": "1.14.4",
    "@types/fs-extra": "11.0.4",
    "@types/is-ci": "3.0.4",
    "@types/lodash.debounce": "4.0.9",
    "@types/node": "24.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "apicalypse": "1.0.5",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "decompress": "4.2.1",
    "decompress-unzip": "4.0.1",
    "del-cli": "7.0.0",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "follow-redirects": "1.16.0",
    "fs-extra": "11.3.5",
    "happy-dom": "20.10.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "madge": "8.0.0",
    "mmarkdown": "1.0.0",
    "oxlint": "1.69.0",
    "prettier": "3.8.4",
    "prop-types": "15.8.1",
    "require-from-string": "2.0.2",
    "shx": "0.4.0",
    "storybook": "10.4.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "utility-types": "3.11.0",
    "vite-plugin-devtools-json": "0.4.1",
    "vitest": "3.2.6",
    "vitest-when": "0.10.0",
    "wait-on": "9.0.10"
  },
  "engines": {
    "node": ">=24"
  },
  "sideEffects": false,
  "mmarkdown": {
    "src": "./readme/Template.md",
    "out": "./README.md",
    "scripts": "./readme/build/readme/scripts.js"
  },
  "exports": "./buildDesktop/desktop/main.js",
  "main": "buildDesktop/desktop/main.js",
  "packageManager": "yarn@4.14.1",
  "type": "module"
}
